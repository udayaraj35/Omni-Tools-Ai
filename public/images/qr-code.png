  <change>
    <file>src/components/ui/buy-me-a-coffee-dialog.tsx</file>
    <content><![CDATA['use client';

import {
  AlertDialog,
  AlertDialogAction,
  AlertDialogCancel,
  AlertDialogContent,
  AlertDialogDescription,
  AlertDialogFooter,
  AlertDialogHeader,
  AlertDialogTitle,
} from '@/components/ui/alert-dialog';
import Image from 'next/image';
import { Coffee, Download, QrCode } from 'lucide-react';
import { Button } from './button';
import { useState } from 'react';
import { Tabs, TabsContent, TabsList, TabsTrigger } from "@/components/ui/tabs";

interface BuyMeACoffeeDialogProps {
  open: boolean;
  onOpenChange: (open: boolean) => void;
}

export function BuyMeACoffeeDialog({ open, onOpenChange }: BuyMeACoffeeDialogProps) {
  const [showQr, setShowQr] = useState(false);

  return (
    <AlertDialog open={open} onOpenChange={(isOpen) => {
        onOpenChange(isOpen);
        if (!isOpen) {
            setShowQr(false); // Reset QR state when closing
        }
    }}>
      <AlertDialogContent className="bg-[#1e293b] border-[#334155] max-w-lg">
        <AlertDialogHeader className="text-center">
            {!showQr ? (
                <>
                    <div className="flex justify-center mb-4">
                        <div className="p-4 bg-yellow-400/10 rounded-full border-2 border-yellow-500/30">
                            <Coffee className="h-12 w-12 text-yellow-400" />
                        </div>
                    </div>
                    <AlertDialogTitle className="text-2xl text-yellow-300">
                        तपाईंको भविष्य सुखमय र राम्रो जागिरको लागि धेरै धेरै शुभकामना!
                    </AlertDialogTitle>
                    <AlertDialogDescription className="text-slate-400 pt-3 text-base">
                        हाम्रो AI tool प्रयोग गरी Europass CV बनाउनु भएकोमा धन्यवाद!
                        <br />
                        यदि तपाईंलाई हाम्रो प्रयास मन पर्यो भने, कृपया हामीलाई सहयोग गर्नुहोस्।
                    </AlertDialogDescription>
                </>
            ) : (
                <div className="flex flex-col items-center">
                     <AlertDialogTitle className="text-xl text-yellow-300">
                        Global IME Bank QR
                    </AlertDialogTitle>
                    <Image src="/images/qr-code.png" alt="Global IME Bank QR Code" width={256} height={256} className="my-4 rounded-md" />
                    <AlertDialogDescription className="text-slate-400">
                       Scan to pay
                    </AlertDialogDescription>
                </div>
            )}
        </AlertDialogHeader>

        {!showQr && (
            <div className="my-4">
                <Tabs defaultValue="nepal" className="w-full">
                    <TabsList className="grid w-full grid-cols-2">
                        <TabsTrigger value="nepal">For Nepal Users</TabsTrigger>
                        <TabsTrigger value="international">For International Users</TabsTrigger>
                    </TabsList>
                    <TabsContent value="nepal" className="mt-4 bg-slate-800/50 p-4 rounded-md">
                         <div className="space-y-4 text-center">
                            <p className="text-sm text-slate-300">तपाईंले हामीलाई सिधै eSewa, Khalti, वा Bank QR मार्फत सहयोग गर्न सक्नुहुन्छ।</p>
                            <div className="flex justify-center items-center gap-4">
                                <a href="https://esewa.com.np/#/home" target="_blank" rel="noopener noreferrer" className="flex flex-col items-center gap-1 text-slate-300 hover:text-white">
                                    <Image src="/images/esewa_logo.png" alt="eSewa" width={40} height={40} />
                                    <span className="text-xs">eSewa</span>
                                </a>
                                <a href="https://khalti.com" target="_blank" rel="noopener noreferrer" className="flex flex-col items-center gap-1 text-slate-300 hover:text-white">
                                    <Image src="/images/khalti_logo.png" alt="Khalti" width={40} height={40} />
                                    <span className="text-xs">Khalti</span>
                                </a>
                                <button onClick={() => setShowQr(true)} className="flex flex-col items-center gap-1 text-slate-300 hover:text-white">
                                    <Image src="/images/globalime_logo.png" alt="Global IME Bank" width={40} height={40} />
                                    <span className="text-xs">Global IME</span>
                                </button>
                            </div>
                            <p className="text-xs text-slate-400">
                                Direct Pay: <strong className="text-slate-200">+977 986 435 3535</strong>
                            </p>
                        </div>
                    </TabsContent>
                    <TabsContent value="international" className="mt-4 bg-slate-800/50 p-4 rounded-md">
                        <div className="text-center space-y-3">
                            <p className="text-sm text-slate-300">You can support us via Buy Me a Coffee.</p>
                            <Button
                                onClick={() => window.open('https://buymeacoffee.com/udayaraj', '_blank')}
                                className="w-full bg-yellow-500 text-black font-bold hover:bg-yellow-400 shadow-md shadow-yellow-500/20 transition-all hover:shadow-lg hover:shadow-yellow-500/30"
                            >
                                <Coffee className="mr-2 h-4 w-4" />
                                Buy Me a Coffee
                            </Button>
                        </div>
                    </TabsContent>
                </Tabs>
            </div>
        )}
        
        <AlertDialogFooter className="sm:justify-center">
            {showQr ? (
                 <Button variant="outline" onClick={() => setShowQr(false)}>Back</Button>
            ) : (
                <AlertDialogCancel className="bg-transparent border-slate-600 hover:bg-slate-700 hover:text-white">Close</AlertDialogCancel>
            )}
        </AlertDialogFooter>
      </AlertDialogContent>
    </AlertDialog>
  );
}
